# 1) Image de base officielle Python 3.11
FROM python:3.11-slim

WORKDIR /app

# 2) Dépendances système
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# 3) Installation et mise à jour des packages Python
COPY Codes/docker/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 4) Téléchargement complet de TOUTES les ressources NLTK requises (sans cache bloquant)
RUN pip install --upgrade nltk && python -m nltk.downloader punkt punkt_tab stopwords wordnet omw-1.4

# 5) Copie de l'arborescence de ton projet
COPY Codes/src/ ./src/
COPY Codes/models/ ./models/
COPY Codes/interface/app.py ./app.py
                                                 
# 6) Copie des Assets à la racine (pour matcher le ../../Assets de Traitement.py)
COPY Assets/ /Assets/

# 7) Configuration de l'environnement et ports
ENV PYTHONPATH="/app/src"
EXPOSE 8000
EXPOSE 8501

# 8) Lancement SIMULTANÉ des deux services (FastAPI via ton script + Streamlit)
CMD ["sh", "-c", "python src/fast.py & python -m streamlit run app.py --server.port 8501 --server.address 0.0.0.0"]